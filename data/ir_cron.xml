<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cron_generer_alertes_garantie" model="ir.cron">
            <field name="name">IT Parc - Générer alertes garanties équipements</field>
            <field name="model_id" ref="model_it_equipement"/>
            <field name="state">code</field>
            <field name="code">model.cron_generer_alertes()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="cron_update_contrats" model="ir.cron">
            <field name="name">IT Parc - Mettre à jour contrats expirés et alertes</field>
            <field name="model_id" ref="model_it_contrat"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_etats()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
