<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_fiche_equipement" model="ir.actions.report">
            <field name="name">Fiche équipement</field>
            <field name="model">it.equipement</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">it_parc.report_fiche_equipement_template</field>
            <field name="report_file">it_parc.report_fiche_equipement_template</field>
            <field name="binding_model_id" ref="model_it_equipement"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <template id="report_fiche_equipement_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="e">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <div class="row mb-4">
                                <div class="col-8">
                                    <h2 class="text-primary">FICHE ÉQUIPEMENT</h2>
                                    <h3><t t-esc="e.name"/></h3>
                                </div>
                                <div class="col-4 text-right">
                                    <span class="badge badge-primary" style="font-size:14px;">
                                        <t t-esc="e.reference"/>
                                    </span>
                                    <br/><br/>
                                    <span class="badge"
                                        t-attf-style="background-color: #{
                                            'brouillon' == e.etat and '#6c757d' or
                                            'affecte' == e.etat and '#28a745' or
                                            'en_maintenance' == e.etat and '#ffc107' or '#dc3545'
                                        }; color:white; font-size:12px; padding:4px 8px;">
                                        <t t-esc="dict([('brouillon','Brouillon'),('affecte','Affecté'),('en_maintenance','En maintenance'),('retire','Retiré')])[e.etat]"/>
                                    </span>
                                </div>
                            </div>
                            <hr/>
                            <div class="row">
                                <div class="col-6">
                                    <h5 class="text-muted mb-2">IDENTIFICATION</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr><th class="bg-light" style="width:45%">Catégorie</th><td><t t-esc="e.categorie"/></td></tr>
                                        <tr><th class="bg-light">Marque</th><td><t t-esc="e.marque or '—'"/></td></tr>
                                        <tr><th class="bg-light">Modèle</th><td><t t-esc="e.modele or '—'"/></td></tr>
                                        <tr><th class="bg-light">N° de série</th><td><t t-esc="e.numero_serie or '—'"/></td></tr>
                                        <tr><th class="bg-light">Localisation</th><td><t t-esc="e.localisation or '—'"/></td></tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <h5 class="text-muted mb-2">ACQUISITION</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr><th class="bg-light" style="width:45%">Fournisseur</th><td><t t-esc="e.fournisseur_id.name or '—'"/></td></tr>
                                        <tr><th class="bg-light">Date d'achat</th><td><t t-field="e.date_achat"/></td></tr>
                                        <tr><th class="bg-light">Valeur d'achat</th><td><t t-esc="'{:,.0f}'.format(e.valeur_achat)"/> FCFA</td></tr>
                                        <tr><th class="bg-light">Fin de garantie</th><td><t t-field="e.date_fin_garantie"/></td></tr>
                                        <tr>
                                            <th class="bg-light">Garantie</th>
                                            <td t-attf-class="#{e.garantie_expiree and 'text-danger' or 'text-success'}">
                                                <t t-esc="e.garantie_expiree and 'Expirée' or (str(e.jours_avant_fin_garantie) + ' jours restants')"/>
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-12">
                                    <h5 class="text-muted mb-2">AFFECTATION COURANTE</h5>
                                    <table class="table table-sm table-bordered">
                                        <tr>
                                            <th class="bg-light" style="width:22%">Employé</th>
                                            <td><t t-esc="e.employee_id.name or '—'"/></td>
                                            <th class="bg-light" style="width:22%">Département</th>
                                            <td><t t-esc="e.department_id.name or '—'"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <t t-if="e.intervention_ids">
                                <div class="row mt-3">
                                    <div class="col-12">
                                        <h5 class="text-muted mb-2">HISTORIQUE INTERVENTIONS (<t t-esc="e.nb_interventions"/>)</h5>
                                        <table class="table table-sm table-bordered table-striped">
                                            <thead class="thead-dark">
                                                <tr>
                                                    <th>Référence</th>
                                                    <th>Date</th>
                                                    <th>Type</th>
                                                    <th>Technicien</th>
                                                    <th>Durée (h)</th>
                                                    <th>Coût (FCFA)</th>
                                                    <th>État</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr t-foreach="e.intervention_ids" t-as="i">
                                                    <td><t t-esc="i.name"/></td>
                                                    <td><t t-field="i.date_debut"/></td>
                                                    <td><t t-esc="i.type_intervention"/></td>
                                                    <td><t t-esc="i.technicien_id.name"/></td>
                                                    <td><t t-esc="i.duree"/></td>
                                                    <td><t t-esc="'{:,.0f}'.format(i.cout)"/></td>
                                                    <td><t t-esc="i.etat"/></td>
                                                </tr>
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="5"><strong>Total maintenance</strong></td>
                                                    <td><strong><t t-esc="'{:,.0f}'.format(e.cout_total_maintenance)"/> FCFA</strong></td>
                                                    <td/>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </t>
                            <t t-if="e.notes">
                                <div class="row mt-3">
                                    <div class="col-12">
                                        <h5 class="text-muted mb-2">NOTES TECHNIQUES</h5>
                                        <p><t t-esc="e.notes"/></p>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
