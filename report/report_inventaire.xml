<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_inventaire" model="ir.actions.report">
            <field name="name">Inventaire du parc</field>
            <field name="model">it.equipement</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">it_parc.report_inventaire_template</field>
            <field name="report_file">it_parc.report_inventaire_template</field>
            <field name="binding_model_id" ref="model_it_equipement"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <template id="report_inventaire_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-3">
                            <div class="col-8">
                                <h2 class="text-primary">INVENTAIRE DU PARC INFORMATIQUE</h2>
                                <p class="text-muted">TECHPARK CI — Généré le <t t-esc="datetime.date.today().strftime('%d/%m/%Y')"/></p>
                            </div>
                            <div class="col-4 text-right">
                                <span class="badge badge-info" style="font-size:13px;">
                                    <t t-esc="len(docs)"/> équipement(s)
                                </span>
                            </div>
                        </div>
                        <hr/>
                        <table class="table table-sm table-bordered table-striped" style="font-size:10px;">
                            <thead style="background-color:#1F4E79; color:white;">
                                <tr>
                                    <th>Référence</th>
                                    <th>Désignation</th>
                                    <th>Catégorie</th>
                                    <th>Marque / Modèle</th>
                                    <th>N° Série</th>
                                    <th>Employé</th>
                                    <th>Département</th>
                                    <th>Fin garantie</th>
                                    <th>État</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="docs" t-as="e"
                                    t-attf-style="#{e.etat == 'retire' and 'color:#999' or (e.garantie_expiree and 'background-color:#FFF2CC' or '')}">
                                    <td><t t-esc="e.reference"/></td>
                                    <td><t t-esc="e.name"/></td>
                                    <td><t t-esc="e.categorie"/></td>
                                    <td><t t-esc="(e.marque or '') + ' ' + (e.modele or '')"/></td>
                                    <td><t t-esc="e.numero_serie or '—'"/></td>
                                    <td><t t-esc="e.employee_id.name or '—'"/></td>
                                    <td><t t-esc="e.department_id.name or '—'"/></td>
                                    <td t-attf-style="#{e.garantie_expiree and 'color:#dc3545;font-weight:bold' or ''}">
                                        <t t-field="e.date_fin_garantie"/>
                                    </td>
                                    <td><t t-esc="e.etat"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="row mt-3">
                            <div class="col-12 text-right text-muted" style="font-size:10px;">
                                Légende: <span style="background:#FFF2CC; padding:2px 6px;">Garantie expirée</span>
                                <span style="color:#999; margin-left:8px;">Retiré du parc</span>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
