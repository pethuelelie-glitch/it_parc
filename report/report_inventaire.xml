<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_inventaire" model="ir.actions.report">
        <field name="name">Inventaire du parc informatique</field>
        <field name="model">it.equipement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_inventaire_template</field>
        <field name="report_file">it_parc/report/report_inventaire</field>
        <field name="binding_model_id" ref="model_it_equipement"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

    <template id="report_inventaire_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">

                    <!-- Titre -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h2 style="color:#1565C0; border-bottom:3px solid #1565C0; padding-bottom:10px;">
                                📋 Inventaire du Parc Informatique
                            </h2>
                            <p class="text-muted">
                                Généré le <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
                                — Total : <strong><t t-esc="len(docs)"/> équipement(s)</strong>
                            </p>
                        </div>
                    </div>

                    <!-- Tableau inventaire -->
                    <table class="table table-bordered table-sm" style="font-size:10px;">
                        <thead style="background:#1565C0; color:white;">
                            <tr>
                                <th style="width:10%;">Référence</th>
                                <th style="width:18%;">Nom</th>
                                <th style="width:10%;">Catégorie</th>
                                <th style="width:8%;">Marque</th>
                                <th style="width:8%;">Modèle</th>
                                <th style="width:10%;">N° Série</th>
                                <th style="width:8%;">État</th>
                                <th style="width:12%;">Employé</th>
                                <th style="width:8%;">Fin garantie</th>
                                <th style="width:8%;">Coût maint. (FCFA)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="cat_map" t-value="{'poste_travail':'PC','serveur':'Serveur','imprimante':'Imprimante','reseau':'Réseau','telephone':'Téléphone','autre':'Autre'}"/>
                            <t t-set="state_map" t-value="{'brouillon':'Brouillon','affecte':'Affecté','en_maintenance':'Maintenance','retire':'Retiré'}"/>
                            <t t-foreach="docs" t-as="o">
                                <tr t-attf-style="background: #{o.garantie_expire and '#fff3f3' or ''}">
                                    <td><t t-esc="o.reference"/></td>
                                    <td><strong><t t-esc="o.name"/></strong></td>
                                    <td><t t-esc="cat_map.get(o.categorie, o.categorie)"/></td>
                                    <td><t t-esc="o.marque or '—'"/></td>
                                    <td><t t-esc="o.modele or '—'"/></td>
                                    <td style="font-family:monospace; font-size:9px;"><t t-esc="o.numero_serie or '—'"/></td>
                                    <td>
                                        <span t-attf-style="color: #{o.state == 'affecte' and '#2e7d32' or o.state == 'en_maintenance' and '#e65100' or o.state == 'retire' and '#c62828' or '#546e7a'}; font-weight:bold;">
                                            <t t-esc="state_map.get(o.state, o.state)"/>
                                        </span>
                                    </td>
                                    <td><t t-esc="o.employee_id.name or '—'"/></td>
                                    <td>
                                        <t t-if="o.date_garantie">
                                            <span t-attf-style="color: #{o.garantie_expire and '#c62828' or '#2e7d32'}">
                                                <t t-esc="o.date_garantie.strftime('%d/%m/%Y')"/>
                                            </span>
                                        </t>
                                        <t t-else="">—</t>
                                    </td>
                                    <td class="text-end">
                                        <t t-esc="'{:,.0f}'.format(o.cout_total_maintenance) if o.cout_total_maintenance else '0'"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot style="background:#f5f7fa;">
                            <tr>
                                <td colspan="9" class="text-end"><strong>Total coûts maintenance :</strong></td>
                                <td class="text-end">
                                    <strong>
                                        <t t-esc="'{:,.0f} FCFA'.format(sum(docs.mapped('cout_total_maintenance')))"/>
                                    </strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <!-- Légende -->
                    <div class="row mt-3">
                        <div class="col-12" style="font-size:9px; color:#666;">
                            <span style="color:#c62828;">&#9632;</span> Fond rouge = garantie expirée &#160;|&#160;
                            <span style="color:#2e7d32;">&#9632;</span> Date verte = garantie valide &#160;|&#160;
                            <span style="color:#c62828;">&#9632;</span> Date rouge = garantie expirée
                        </div>
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
