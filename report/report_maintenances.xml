<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_report_maintenances" model="ir.actions.report">
            <field name="name">Historique des maintenances</field>
            <field name="model">it.intervention</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">it_parc.report_maintenances_template</field>
            <field name="report_file">it_parc.report_maintenances_template</field>
            <field name="binding_model_id" ref="model_it_intervention"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="base.paperformat_euro"/>
        </record>

        <template id="report_maintenances_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row mb-3">
                            <div class="col-8">
                                <h2 class="text-primary">RAPPORT DE MAINTENANCE</h2>
                                <p class="text-muted">TECHPARK CI — <t t-esc="len(docs)"/> intervention(s)</p>
                            </div>
                        </div>
                        <hr/>
                        <table class="table table-sm table-bordered" style="font-size:10px;">
                            <thead style="background-color:#1F4E79; color:white;">
                                <tr>
                                    <th>Référence</th>
                                    <th>Équipement</th>
                                    <th>Type</th>
                                    <th>Technicien</th>
                                    <th>Date début</th>
                                    <th>Date fin</th>
                                    <th>Durée (h)</th>
                                    <th>Coût (FCFA)</th>
                                    <th>État</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="docs" t-as="i"
                                    t-attf-style="#{i.etat == 'annule' and 'color:#999' or ''}">
                                    <td><t t-esc="i.name"/></td>
                                    <td><t t-esc="i.equipement_id.name"/></td>
                                    <td><t t-esc="i.type_intervention"/></td>
                                    <td><t t-esc="i.technicien_id.name or '—'"/></td>
                                    <td><t t-field="i.date_debut"/></td>
                                    <td><t t-field="i.date_fin"/></td>
                                    <td><t t-esc="'{:.1f}'.format(i.duree)"/></td>
                                    <td><t t-esc="'{:,.0f}'.format(i.cout)"/></td>
                                    <td><t t-esc="i.etat"/></td>
                                </tr>
                            </tbody>
                            <tfoot style="background-color:#F0F0F0;">
                                <tr>
                                    <td colspan="7"><strong>TOTAL</strong></td>
                                    <td><strong><t t-esc="'{:,.0f}'.format(sum(docs.mapped('cout')))"/> FCFA</strong></td>
                                    <td/>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
