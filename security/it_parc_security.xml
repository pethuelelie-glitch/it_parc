<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_it_parc" model="ir.module.category">
            <field name="name">IT Parc</field>
            <field name="description">Gestion du parc informatique TECHPARK CI</field>
            <field name="sequence">25</field>
        </record>

        <record id="group_it_parc_technicien" model="res.groups">
            <field name="name">IT Technicien</field>
            <field name="category_id" ref="module_category_it_parc"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Lecture du parc + création et gestion des interventions.</field>
        </record>

        <record id="group_it_parc_manager" model="res.groups">
            <field name="name">IT Responsable</field>
            <field name="category_id" ref="module_category_it_parc"/>
            <field name="implied_ids" eval="[(4, ref('group_it_parc_technicien'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Accès complet au module IT Parc.</field>
        </record>

    </data>
</odoo>
