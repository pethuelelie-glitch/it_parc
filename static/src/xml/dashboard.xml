<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="it_parc.Dashboard">
        <div class="it-parc-dashboard o_action_manager">
            <div class="o_control_panel">
                <div class="o_cp_top">
                    <h2 class="ms-3 mt-2">Tableau de bord — Parc Informatique</h2>
                </div>
            </div>
            <div class="container-fluid mt-3">
                <!-- KPIs -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="text-muted small mb-1">Total équipements</div>
                                <div class="display-5 fw-bold text-primary"><t t-esc="state.total"/></div>
                                <i class="fa fa-desktop fa-lg text-primary mt-1"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="text-muted small mb-1">Affectés</div>
                                <div class="display-5 fw-bold text-success"><t t-esc="state.actifs"/></div>
                                <i class="fa fa-check-circle fa-lg text-success mt-1"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="text-muted small mb-1">En maintenance</div>
                                <div class="display-5 fw-bold text-warning"><t t-esc="state.en_maintenance"/></div>
                                <i class="fa fa-wrench fa-lg text-warning mt-1"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-body text-center">
                                <div class="text-muted small mb-1">Alertes actives</div>
                                <div class="display-5 fw-bold text-danger"><t t-esc="state.alertes_actives"/></div>
                                <i class="fa fa-exclamation-triangle fa-lg text-danger mt-1"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Coût + Graphique -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-semibold">Coût maintenance ce mois</div>
                            <div class="card-body text-center d-flex flex-column justify-content-center">
                                <div class="display-6 fw-bold text-info">
                                    <t t-esc="state.cout_mois"/>
                                    <small class="fs-6 text-muted ms-1">FCFA</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-semibold">Répartition par catégorie</div>
                            <div class="card-body p-2">
                                <canvas id="it_parc_cat_chart" style="max-height:220px;"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Raccourcis -->
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm text-decoration-none text-dark"
                            style="cursor:pointer;"
                            t-on-click="() => this.navTo('it.equipement')">
                            <div class="card-body text-center py-3">
                                <i class="fa fa-list fa-lg me-2 text-primary"/>Équipements
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm text-decoration-none text-dark"
                            style="cursor:pointer;"
                            t-on-click="() => this.navTo('it.intervention')">
                            <div class="card-body text-center py-3">
                                <i class="fa fa-wrench fa-lg me-2 text-warning"/>Interventions
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm text-decoration-none text-dark"
                            style="cursor:pointer;"
                            t-on-click="() => this.navTo('it.contrat')">
                            <div class="card-body text-center py-3">
                                <i class="fa fa-file-text fa-lg me-2 text-info"/>Contrats
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm text-decoration-none text-dark"
                            style="cursor:pointer;"
                            t-on-click="() => this.navTo('it.alerte')">
                            <div class="card-body text-center py-3">
                                <i class="fa fa-bell fa-lg me-2 text-danger"/>Alertes
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
