<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_it_affectation_list" model="ir.ui.view">
        <field name="name">it.affectation.list</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <list>
                <field name="equipement_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="motif"/>
            </list>
        </field>
    </record>

    <record id="view_it_affectation_form" model="ir.ui.view">
        <field name="name">it.affectation.form</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Équipement">
                            <field name="equipement_id"/>
                        </group>
                        <group string="Affectation">
                            <field name="employee_id"/>
                            <field name="department_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Période">
                            <field name="date_debut"/>
                            <field name="date_fin"/>
                        </group>
                    </group>
                    <group>
                        <field name="motif" placeholder="Motif du changement d'affectation…"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_it_affectation_search" model="ir.ui.view">
        <field name="name">it.affectation.search</field>
        <field name="model">it.affectation</field>
        <field name="arch" type="xml">
            <search>
                <field name="equipement_id"/>
                <field name="employee_id"/>
                <field name="department_id"/>
                <filter string="En cours" name="en_cours" domain="[('date_fin','=',False)]"/>
                <group expand="0" string="Grouper par">
                    <filter string="Équipement" name="by_eq" context="{'group_by': 'equipement_id'}"/>
                    <filter string="Employé" name="by_emp" context="{'group_by': 'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
