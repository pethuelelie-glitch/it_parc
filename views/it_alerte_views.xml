<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_it_alerte_list" model="ir.ui.view">
            <field name="name">it.alerte.list</field>
            <field name="model">it.alerte</field>
            <field name="arch" type="xml">
                <list string="Alertes" decoration-danger="etat == 'actif'" decoration-it="etat != 'actif'">
                    <field name="name"/>
                    <field name="type_alerte"/>
                    <field name="equipement_id"/>
                    <field name="contrat_id"/>
                    <field name="date_echeance"/>
                    <field name="message"/>
                    <field name="etat" widget="badge"
                        decoration-danger="etat == 'actif'"
                        decoration-success="etat == 'traite'"
                        decoration-warning="etat == 'ignore'"/>
                    <button name="action_traiter" string="Traiter" type="object"
                        icon="fa-check" invisible="etat != 'actif'"/>
                    <button name="action_ignorer" string="Ignorer" type="object"
                        icon="fa-times" invisible="etat != 'actif'"/>
                </list>
            </field>
        </record>

        <record id="view_it_alerte_form" model="ir.ui.view">
            <field name="name">it.alerte.form</field>
            <field name="model">it.alerte</field>
            <field name="arch" type="xml">
                <form string="Alerte">
                    <header>
                        <button name="action_traiter" string="Marquer traitée" type="object"
                            class="btn-primary" invisible="etat != 'actif'"/>
                        <button name="action_ignorer" string="Ignorer" type="object"
                            invisible="etat != 'actif'"/>
                        <field name="etat" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="type_alerte"/>
                                <field name="date_echeance"/>
                            </group>
                            <group>
                                <field name="equipement_id" invisible="type_alerte != 'garantie'"/>
                                <field name="contrat_id" invisible="type_alerte != 'contrat'"/>
                            </group>
                        </group>
                        <field name="message" placeholder="Message de l'alerte..."/>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_it_alerte_search" model="ir.ui.view">
            <field name="name">it.alerte.search</field>
            <field name="model">it.alerte</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="equipement_id"/>
                    <field name="contrat_id"/>
                    <filter string="Actives" name="actives" domain="[('etat','=','actif')]"/>
                    <filter string="Traitées" name="traitees" domain="[('etat','=','traite')]"/>
                    <separator/>
                    <filter string="Garanties" name="garanties" domain="[('type_alerte','=','garantie')]"/>
                    <filter string="Contrats" name="contrats" domain="[('type_alerte','=','contrat')]"/>
                    <group expand="0" string="Grouper par">
                        <filter name="g_type" string="Type" context="{'group_by': 'type_alerte'}"/>
                        <filter name="g_etat" string="État" context="{'group_by': 'etat'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_it_alerte" model="ir.actions.act_window">
            <field name="name">Alertes actives</field>
            <field name="res_model">it.alerte</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('etat','=','actif')]</field>
            <field name="search_view_id" ref="view_it_alerte_search"/>
        </record>
    </data>
</odoo>
