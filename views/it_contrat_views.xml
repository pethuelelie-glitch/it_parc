<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_it_contrat_form" model="ir.ui.view">
            <field name="name">it.contrat.form</field>
            <field name="model">it.contrat</field>
            <field name="arch" type="xml">
                <form string="Contrat fournisseur">
                    <header>
                        <button name="action_activer" string="Activer" type="object"
                            class="btn-primary" invisible="etat != 'brouillon'"/>
                        <button name="action_renouveler" string="Renouveler" type="object"
                            invisible="etat not in ['actif','expire']"
                            groups="it_parc.group_it_parc_manager"/>
                        <button name="action_resilier" string="Résilier" type="object"
                            invisible="etat != 'actif'"
                            groups="it_parc.group_it_parc_manager"/>
                        <field name="etat" widget="statusbar"
                            statusbar_visible="brouillon,actif,expire"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Intitulé du contrat"/></h1>
                            <h3 class="text-muted"><field name="reference" readonly="True"/></h3>
                        </div>
                        <group>
                            <group>
                                <field name="fournisseur_id"/>
                                <field name="type_contrat"/>
                                <field name="montant"/>
                            </group>
                            <group>
                                <field name="date_debut"/>
                                <field name="date_fin"/>
                                <field name="jours_restants" readonly="True"/>
                                <field name="expire" readonly="True"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Équipements couverts">
                                <field name="equipement_ids">
                                    <list>
                                        <field name="reference"/>
                                        <field name="name"/>
                                        <field name="categorie"/>
                                        <field name="employee_id"/>
                                        <field name="etat" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Alertes">
                                <field name="alerte_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="date_echeance"/>
                                        <field name="etat" widget="badge"
                                            decoration-danger="etat == 'actif'"
                                            decoration-success="etat == 'traite'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes">
                                <field name="notes" placeholder="Notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_it_contrat_list" model="ir.ui.view">
            <field name="name">it.contrat.list</field>
            <field name="model">it.contrat</field>
            <field name="arch" type="xml">
                <list string="Contrats"
                    decoration-danger="expire == True"
                    decoration-it="etat in ['resilie','renouvele']">
                    <field name="reference"/>
                    <field name="name"/>
                    <field name="type_contrat"/>
                    <field name="fournisseur_id"/>
                    <field name="date_debut"/>
                    <field name="date_fin"/>
                    <field name="jours_restants"/>
                    <field name="montant"/>
                    <field name="expire" column_invisible="True"/>
                    <field name="etat" widget="badge"
                        decoration-primary="etat == 'brouillon'"
                        decoration-success="etat == 'actif'"
                        decoration-danger="etat == 'expire'"
                        decoration-info="etat == 'renouvele'"
                        decoration-warning="etat == 'resilie'"/>
                </list>
            </field>
        </record>

        <record id="view_it_contrat_search" model="ir.ui.view">
            <field name="name">it.contrat.search</field>
            <field name="model">it.contrat</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="fournisseur_id"/>
                    <filter string="Actifs" name="actifs" domain="[('etat','=','actif')]"/>
                    <filter string="Expirés" name="expires" domain="[('etat','=','expire')]"/>
                    <filter string="Expirant dans 60j" name="bientot" domain="[('etat','=','actif'),('jours_restants','&lt;=',60)]"/>
                    <group expand="0" string="Grouper par">
                        <filter name="g_type" string="Type" context="{'group_by': 'type_contrat'}"/>
                        <filter name="g_fourn" string="Fournisseur" context="{'group_by': 'fournisseur_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_it_contrat" model="ir.actions.act_window">
            <field name="name">Contrats fournisseurs</field>
            <field name="res_model">it.contrat</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_it_contrat_search"/>
        </record>
    </data>
</odoo>
