<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Action dashboard client -->
        <record id="action_it_parc_dashboard" model="ir.actions.client">
            <field name="name">Tableau de bord IT</field>
            <field name="tag">it_parc_dashboard_action</field>
        </record>

        <!-- Actions export Excel -->
        <record id="action_export_inventaire" model="ir.actions.act_window">
            <field name="name">Export inventaire Excel</field>
            <field name="res_model">wizard.export.excel</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_type_export': 'inventaire'}</field>
        </record>
        <record id="action_export_couts" model="ir.actions.act_window">
            <field name="name">Export coûts maintenance Excel</field>
            <field name="res_model">wizard.export.excel</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_type_export': 'couts_maintenance'}</field>
        </record>
        <record id="action_export_contrats" model="ir.actions.act_window">
            <field name="name">Export contrats expiration Excel</field>
            <field name="res_model">wizard.export.excel</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
            <field name="context">{'default_type_export': 'contrats_expiration'}</field>
        </record>

        <!-- ═══ MENU PRINCIPAL ═══ -->
        <menuitem id="menu_it_parc_root"
            name="IT Parc"
            sequence="50"/>

        <!-- Tableau de bord -->
        <menuitem id="menu_it_dashboard"
            name="Tableau de bord"
            parent="menu_it_parc_root"
            action="action_it_parc_dashboard"
            sequence="1"/>

        <!-- Équipements -->
        <menuitem id="menu_it_equipements"
            name="Équipements"
            parent="menu_it_parc_root"
            sequence="10"/>
        <menuitem id="menu_it_equipement_list"
            name="Tous les équipements"
            parent="menu_it_equipements"
            action="action_it_equipement"
            sequence="10"/>
        <menuitem id="menu_it_affectations"
            name="Affectations"
            parent="menu_it_equipements"
            action="action_it_affectation"
            sequence="20"/>

        <!-- Maintenance -->
        <menuitem id="menu_it_maintenance"
            name="Maintenance"
            parent="menu_it_parc_root"
            sequence="20"/>
        <menuitem id="menu_it_interventions"
            name="Interventions"
            parent="menu_it_maintenance"
            action="action_it_intervention"
            sequence="10"/>

        <!-- Contrats & Alertes -->
        <menuitem id="menu_it_contrats_alertes"
            name="Contrats &amp; Alertes"
            parent="menu_it_parc_root"
            sequence="30"/>
        <menuitem id="menu_it_contrats"
            name="Contrats fournisseurs"
            parent="menu_it_contrats_alertes"
            action="action_it_contrat"
            sequence="10"/>
        <menuitem id="menu_it_alertes"
            name="Alertes actives"
            parent="menu_it_contrats_alertes"
            action="action_it_alerte"
            sequence="20"/>

        <!-- Imports & Exports -->
        <menuitem id="menu_it_imports_exports"
            name="Imports &amp; Exports"
            parent="menu_it_parc_root"
            sequence="40"
            groups="it_parc.group_it_parc_manager"/>
        <menuitem id="menu_it_import_csv"
            name="Import CSV équipements"
            parent="menu_it_imports_exports"
            action="action_wizard_import_csv"
            sequence="10"
            groups="it_parc.group_it_parc_manager"/>
        <menuitem id="menu_it_export_inventaire"
            name="Export inventaire (Excel)"
            parent="menu_it_imports_exports"
            action="action_export_inventaire"
            sequence="20"/>
        <menuitem id="menu_it_export_couts"
            name="Export coûts maintenance (Excel)"
            parent="menu_it_imports_exports"
            action="action_export_couts"
            sequence="30"/>
        <menuitem id="menu_it_export_contrats"
            name="Export contrats expiration (Excel)"
            parent="menu_it_imports_exports"
            action="action_export_contrats"
            sequence="40"/>

        <!-- Configuration -->
        <menuitem id="menu_it_config"
            name="Configuration"
            parent="menu_it_parc_root"
            sequence="90"
            groups="it_parc.group_it_parc_manager"/>
        <menuitem id="menu_it_scan_alertes"
            name="Scanner les alertes"
            parent="menu_it_config"
            action="action_wizard_scan_alertes"
            sequence="10"/>

    </data>
</odoo>
