<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wizard_import_csv_form" model="ir.ui.view">
        <field name="name">wizard.import.csv.form</field>
        <field name="model">wizard.import.csv</field>
        <field name="arch" type="xml">
            <form string="Importer des équipements (CSV)">
                <sheet>
                    <!-- Guide colonnes CSV attendues -->
                    <div class="alert alert-secondary" role="alert" invisible="import_fait">
                        <strong>Format CSV attendu :</strong>
                        <code>name;categorie;marque;modele;numero_serie;localisation;date_achat;date_garantie;valeur_achat</code>
                        <br/>
                        Catégories valides : <code>poste_travail</code>, <code>serveur</code>,
                        <code>imprimante</code>, <code>reseau</code>, <code>telephone</code>, <code>autre</code>
                        <br/>
                        Dates au format <code>DD/MM/YYYY</code>.
                        Les doublons sont détectés par numéro de série.
                    </div>

                    <group invisible="import_fait">
                        <group string="Fichier à importer">
                            <field name="fichier_csv" widget="binary" filename="fichier_nom"
                                   required="not import_fait"/>
                            <field name="fichier_nom" invisible="1"/>
                            <field name="separateur" required="1"/>
                        </group>
                    </group>

                    <!-- Rapport d'import -->
                    <group invisible="not import_fait">
                        <group string="Résumé">
                            <field name="nb_crees" readonly="1"/>
                            <field name="nb_ignores" readonly="1"/>
                            <field name="nb_erreurs" readonly="1"/>
                        </group>
                    </group>

                    <div invisible="not import_fait">
                        <field name="resultat_html" widget="html" readonly="1"/>
                    </div>
                </sheet>
                <footer>
                    <button name="action_importer" string="Lancer l'import"
                            type="object" class="btn-primary"
                            invisible="import_fait"/>
                    <button string="Fermer" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
