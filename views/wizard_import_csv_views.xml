<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wizard_import_csv_form" model="ir.ui.view">
            <field name="name">wizard.import.csv.form</field>
            <field name="model">wizard.import.csv</field>
            <field name="arch" type="xml">
                <form string="Import en masse — CSV">
                    <sheet>
                        <group string="Fichier" invisible="traite">
                            <field name="fichier_csv" widget="binary" filename="nom_fichier"/>
                            <field name="nom_fichier" invisible="True"/>
                            <field name="separateur"/>
                        </group>
                        <group string="Résultats" invisible="not traite">
                            <field name="nb_crees" readonly="True"/>
                            <field name="nb_ignores" readonly="True" string="Doublons ignorés"/>
                            <field name="nb_erreurs" readonly="True"/>
                        </group>
                        <field name="rapport" readonly="True" invisible="not traite"
                            placeholder="Le rapport apparaîtra ici après l'import."/>
                        <div class="alert alert-info" invisible="traite">
                            <strong>Colonnes attendues dans le CSV :</strong><br/>
                            <b>Obligatoires :</b> name, categorie (ordinateur | portable | serveur | imprimante | reseau | telephone_ip | autre)<br/>
                            <b>Optionnelles :</b> marque, modele, numero_serie, localisation, valeur_achat,
                            date_achat (JJ/MM/AAAA), date_fin_garantie (JJ/MM/AAAA), notes
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_importer" string="Importer" type="object"
                            class="btn-primary" invisible="traite"/>
                        <button string="Fermer" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_wizard_import_csv" model="ir.actions.act_window">
            <field name="name">Import CSV équipements</field>
            <field name="res_model">wizard.import.csv</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
