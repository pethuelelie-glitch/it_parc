<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wizard_reaffectation_form" model="ir.ui.view">
            <field name="name">wizard.reaffectation.form</field>
            <field name="model">wizard.reaffectation</field>
            <field name="arch" type="xml">
                <form string="Affecter / Réaffecter l'équipement">
                    <sheet>
                        <group string="Équipement">
                            <field name="equipement_id" readonly="True"/>
                            <field name="ancien_employee_id" readonly="True"/>
                            <field name="ancien_department_id" readonly="True"/>
                        </group>
                        <group string="Nouvelle affectation">
                            <field name="nouvel_employee_id"/>
                            <field name="nouveau_department_id"/>
                            <field name="date_reaffectation"/>
                            <field name="motif" required="True" placeholder="Motif de la réaffectation..."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_reaffecter" string="Confirmer l'affectation" type="object" class="btn-primary"/>
                        <button string="Annuler" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
