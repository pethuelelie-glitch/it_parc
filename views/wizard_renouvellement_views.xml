<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_wizard_renouvellement_form" model="ir.ui.view">
            <field name="name">wizard.renouvellement.form</field>
            <field name="model">wizard.renouvellement</field>
            <field name="arch" type="xml">
                <form string="Renouveler le contrat">
                    <sheet>
                        <group>
                            <field name="contrat_id" readonly="True"/>
                            <field name="nouvelle_date_debut"/>
                            <field name="nouvelle_date_fin"/>
                            <field name="nouveau_montant" widget="monetary" options="{'currency_field': False}"/>
                            <field name="notes" placeholder="Remarques sur le renouvellement..."/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_renouveler" string="Renouveler" type="object" class="btn-primary"/>
                        <button string="Annuler" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
